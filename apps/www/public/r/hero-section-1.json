.625 194.591C106.303 197.296 100 193.429 100 187.459V100Z\"\n                fill={uniColor ? 'currentColor' : 'url(#paint_logo)'}\n            />\n            <defs>\n                <linearGradient\n                    id=\"paint_logo\"\n                    x1=\"90\"\n                    y1=\"0\"\n                    x2=\"90\"\n                    y2=\"220\"\n                    gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#9B99FE\" />\n                    <stop\n                        offset=\"1\"\n                        stopColor=\"#2BC8B7\"\n                    />\n                </linearGradient>\n            </defs>\n        </svg>\n    )\n}\n",
