62.208 579.273 160.89 583.828 158.254C588.383 155.618 592.04 151.784 594.797 146.752C597.674 141.6 599.112 135.61 599.112 128.78ZM665.415 93.7356C668.412 88.7035 672.368 84.8096 677.283 82.0539C682.318 79.1784 688.251 77.7407 695.084 77.7407V98.9474H689.87C681.838 98.9474 675.724 100.984 671.529 105.058C667.453 109.131 665.415 116.2 665.415 126.264V178.383H644.917V79.3582H665.415V93.7356ZM751.328 128.96L797 178.383H769.309L732.627 135.789V178.383H712.129V45.3915H732.627V122.67L768.59 79.3582H797L751.328 128.96Z\"\n                fill=\"currentColor\"\n            />\n            <defs>\n                <linearGradient\n                    id=\"paint_logo\"\n                    x1=\"90\"\n                    y1=\"0\"\n                    x2=\"90\"\n                    y2=\"220\"\n                    gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#9B99FE\" />\n                    <stop\n                        offset=\"1\"\n                        stopColor=\"#2BC8B7\"\n                    />\n                </linearGradient>\n            </defs>\n        </svg>\n    )\n}\n\nexport const LogoIcon = ({ className, uniColor }: { className?: string; uniColor?: boolean }) => {\n    return (\n        <svg\n            className={cn('size-6', className)}\n            viewBox=\"0 0 180 220\"\n            fill=\"none\"\n            xmlns=\"http://www.w3.org/2000/svg\">\n            <path\n                fillRule=\"evenodd\"\n                clipRule=\"evenodd\"\n                d=\"M80 100H28C12.536 100 0 87.464 0 72V28C0 12.536 12.536 0 28 0H72C87.464 0 100 12.536 100 28V80H160C171.046 80 180 88.9543 180 100V167.639C180 175.215 175.72 182.14 168.944 185.528L103.416 218.292C101.17 219.415 98.6923 220 96.1803 220C87.2442 220 80 212.756 80 203.82V100ZM28 20C23.5817 20 20 23.5817 20 28V72C20 76.4183 23.5817 80 28 80H80V28C80 23.5817 76.4183 20 72 20H28ZM100 100H152C156.418 100 160 103.582 160 108V165.092C160 168.103 158.309 170.859 155.625 172.224L111.625 194.591C106.303 197.296 100 193.429 100 187.459V100Z\"\n                fill={uniColor ? 'currentColor' : 'url(#paint_logo)'}\n            />\n            <defs>\n                <linearGradient\n                    id=\"paint_logo\"\n                    x1=\"90\"\n                    y1=\"0\"\n                    x2=\"90\"\n                    y2=\"220\"\n                    gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#9B99FE\" />\n                    <stop\n                        offset=\"1\"\n                        stopColor=\"#2BC8B7\"\n                    />\n                </linearGradient>\n            </defs>\n        </svg>\n    )\n}\n",
